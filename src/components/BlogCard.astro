---
/* BlogCard.astro — single card in the blog grid */
interface Props {
  title: string;
  slug: string;
  category: string;
  excerpt: string;
  date: string;
  emoji?: string;
}

const { title, slug, category, excerpt, date, emoji = '📄' } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="blog-card">
  <div class="blog-card-img">{emoji}</div>
  <div class="blog-card-body">
    <div class="blog-card-category">{category}</div>
    <h3>{title}</h3>
    <p>{excerpt}</p>
    <div class="blog-card-meta">{formattedDate}</div>
  </div>
</a>

<style>
  .blog-card {
    display: block;
    background: var(--white);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(10, 22, 40, 0.08);
    border-color: rgba(42, 157, 143, 0.2);
  }

  .blog-card-img {
    height: 200px;
    background: var(--gray-100);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    position: relative;
  }
  .blog-card-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(42, 157, 143, 0.06), rgba(224, 164, 88, 0.06));
  }

  .blog-card-body { padding: 1.5rem; }

  .blog-card-category {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 0.5rem;
  }

  .blog-card-body h3 {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--navy);
    line-height: 1.3;
    margin-bottom: 0.65rem;
  }

  .blog-card-body p {
    font-size: 0.88rem;
    color: var(--gray-500);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .blog-card-meta {
    font-size: 0.78rem;
    color: var(--gray-400);
  }
</style>
