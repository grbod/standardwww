---
/*  BaseLayout.astro
    Wraps every page. Provides <head>, Header, Footer.
    Props: title, description (for SEO <meta> tags)          */

interface Props {
  title: string;
  description?: string;
}

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description = 'Contract manufacturing for dietary supplements — protein powders, capsules, stick packs, and pouches. FDA-registered facility in St. Petersburg, FL.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | Body Nutrition</title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />

<!-- Favicon (replace with your own) -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | Body Nutrition`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>

<script>
  // Minimal JS — just for mobile nav toggle
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    if (toggle && links) {
      toggle.addEventListener('click', () => {
        links.classList.toggle('open');
        toggle.classList.toggle('open');
      });
    }
  });
</script>
