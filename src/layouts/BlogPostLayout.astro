---
/* BlogPostLayout.astro
   Layout for individual blog posts.
   The markdown body renders into <slot />.
   Frontmatter fields are passed as props.           */

import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const { title, category, date, excerpt, emoji = '📄' } = frontmatter;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Get all blog posts for sidebar "Related Articles"
const allPosts = await Astro.glob('../content/blog/*.md');
const related = allPosts
  .filter((p) => p.frontmatter.title !== title)
  .slice(0, 4);
---

<BaseLayout title={title} description={excerpt}>

  <!-- Post Hero -->
  <div class="post-hero">
    <div class="post-hero-inner">
      <div class="post-category">{category}</div>
      <h1>{title}</h1>
      <div class="post-meta">By Body Nutrition · {formattedDate}</div>
    </div>
  </div>

  <!-- Two-column layout: content + sidebar -->
  <div class="post-layout">

    <!-- THIS IS <slot /> — where the markdown body renders as HTML -->
    <article class="post-content">
      <slot />
    </article>

    <!-- Sidebar -->
    <aside class="post-sidebar">
      <div class="sidebar-card">
        <h4>Related Articles</h4>
        <div class="sidebar-related">
          {related.map((p) => (
            <a href={`/blog/${p.frontmatter.slug}`}>{p.frontmatter.title}</a>
          ))}
        </div>
      </div>

      <div class="sidebar-card sidebar-cta">
        <h4>Work With Us</h4>
        <p>Interested in this ingredient?</p>
        <a href="/contact" class="btn btn-primary" style="width:100%;justify-content:center;">
          Request Samples →
        </a>
      </div>
    </aside>
  </div>

</BaseLayout>

<style>
  /* ---- Post Hero ---- */
  .post-hero {
    padding: 8rem 2rem 3rem;
    background: var(--navy);
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .post-hero::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -15%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(42, 157, 143, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .post-hero-inner {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .post-category {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--teal-light);
    margin-bottom: 1.25rem;
  }

  .post-hero h1 {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 1.25rem;
  }

  .post-meta {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.9rem;
  }

  /* ---- Post Layout ---- */
  .post-layout {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 4rem;
  }

  /* ---- Post Content (styled markdown output) ---- */
  .post-content {
    max-width: 720px;
  }

  .post-content :global(h2) {
    font-family: var(--serif);
    font-size: 1.8rem;
    color: var(--navy);
    margin: 2.5rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid rgba(42, 157, 143, 0.15);
  }

  .post-content :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--navy);
    margin: 2rem 0 0.75rem;
  }

  .post-content :global(p) {
    color: var(--gray-600);
    line-height: 1.85;
    margin-bottom: 1.25rem;
    font-size: 1.02rem;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 1rem 0 1.5rem 1.25rem;
    color: var(--gray-600);
    line-height: 1.85;
  }

  .post-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-content :global(blockquote) {
    border-left: 3px solid var(--teal);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: rgba(42, 157, 143, 0.04);
    border-radius: 0 var(--radius) var(--radius) 0;
  }
  .post-content :global(blockquote p) {
    color: var(--navy);
    font-style: italic;
    font-family: var(--serif);
    font-size: 1.1rem;
    margin: 0;
  }

  .post-content :global(strong) {
    color: var(--navy);
    font-weight: 600;
  }

  /* ---- Sidebar ---- */
  .post-sidebar {
    position: sticky;
    top: 96px;
    align-self: start;
  }

  .sidebar-card {
    background: var(--gray-100);
    border: 1px solid var(--gray-200);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .sidebar-card h4 {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray-400);
    margin-bottom: 1rem;
  }

  .sidebar-related {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .sidebar-related a {
    font-size: 0.9rem;
    color: var(--navy);
    font-weight: 500;
    line-height: 1.4;
    transition: color 0.2s;
  }
  .sidebar-related a:hover { color: var(--teal); }

  .sidebar-cta {
    background: var(--navy) !important;
    border-color: transparent !important;
    text-align: center;
  }
  .sidebar-cta h4 { color: rgba(255, 255, 255, 0.5); }
  .sidebar-cta p {
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--serif);
    font-size: 1.1rem;
    margin-bottom: 1.25rem;
  }

  @media (max-width: 768px) {
    .post-layout {
      grid-template-columns: 1fr;
    }
    .post-sidebar {
      position: static;
    }
  }
</style>
